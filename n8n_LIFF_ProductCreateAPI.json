      "name": "OpenAI Tag Classifier"
    },
    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  const t =\n    item.json?.output?.[0]?.content?.find(c => c.type === \"output_text\")?.text\n    ?? item.json?.output_text;\n\n  if (!t) return { json: { ...item.json, parse_error: \"No output_text\" } };\n\n  const cleaned = t.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n  try {\n    return { json: { ...item.json, ...JSON.parse(cleaned) } };\n  } catch (e) {\n    return { json: { ...item.json, parse_error: \"JSON.parse failed\", rawText: t } };\n  }\n});"
      },
