        "body": "={\n  \"model\": \"gpt-4o-mini\",\n  \"input\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"input_text\",\n          \"text\": \"分析這張圖片是否為精品吊牌，並抽取品牌、型號、原價與幣別。只輸出純JSON。\"\n        },\n        {\n          \"type\": \"input_image\",\n          \"image_url\": \"{{ $json.img_url }}\"\n        }\n      ]\n    }\n  ]\n}",
